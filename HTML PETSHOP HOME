<!doctype html>
<html class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <title>PetVille</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="pt-24 bg-white-100 text-gray-800 font-sans">

<header class="fixed top-0 w-full bg-white shadow-sm z-50">

  <div class="max-w-7xl mx-auto px-4 py-3">

    <!-- linha principal -->
    <div class="grid grid-cols-3 items-center">

      <!-- logo -->
      <img src="imgs/petville.png" class="w-28 md:w-40 h-auto">

      <!-- barra de busca -->
      <div class="relative w-[250px] md:w-[500px] mx-auto">

        <img src="imgs/lupa.png"
        class="absolute left-3 top-1/2 -translate-y-1/2 w-4">

        <input
        type="text"
        placeholder="O que seu pet precisa?"
        class="w-full pl-10 pr-4 py-2 bg-gray-100 rounded-full outline-none focus:ring-2 focus:ring-pink-300">
        
      </div>

      <!-- login -->
      <div class="flex justify-end">
       <img src="imgs/config.png"
       class="w-6 cursor-pointer transition duration-200 transform hover:scale-110 active:scale-95"
       onclick="window.location.href='admin.html'">
      </div>

    </div>

    <!-- menu -->
    <nav class="flex justify-center gap-10 mt-0 text-gray-700 font-medium">
    <a href="#home" class="hover:text-green-400">Home</a>
    <a href="#categorias" class="hover:text-green-400">Categorias</a>
    <a href="#servicos" class="hover:text-green-400">Serviços</a>
    <a href="#contatos" class="hover:text-green-400">Contatos</a>

    </nav>

  </div>

</header>

<section id="home" class="w-full h-[250px] md:h-[850px] overflow-hidden">
  <img src="imgs/banner.png" alt="banner"
       class="w-full h-full object-cover block">
</section>


<section id="categorias" class="bg-[#C2DA93] py-20 px-8">

  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-16">

    <!-- título lateral -->
    <div class="md:w-1/4 flex justify-center items-center h-full">
      <h2 class="text-5xl font-bold text-lime-800 leading-tight text-center">
        Para <br> cada Pet
      </h2>
    </div>

    <!-- categorias -->
    <div class="md:w-3/4">
      <div id="categoriasHome" class="grid grid-cols-2 md:grid-cols-4 gap-8 items-start">
      </div>


  </div>

</section>


<section id="servicos" class="py-16 bg-rose-200">
  <h4 class="text-center text-black-400 font-bold text-xl mb-10">
    Cuidados Essenciais
  </h4>

  <div class="flex flex-wrap justify-center gap-8 px-6">

   
    <div class="bg-white w-72 p-6 rounded-2xl shadow-lg text-center hover:scale-105 transition flex flex-col">
      <h3 class="text-xl font-bold mb-2">🐾 Banho e Tosa</h3>
      <p class="text-gray-700 font-semibold">R$99,99</p>
      <p class="mt-2 text-sm">Higiene completa e cuidado especial para deixar seu pet limpo, cheiroso e com o visual sempre em dia. Inclui banho, secagem e tosa personalizada.</p>
      <button class="mt-auto bg-pink-300 hover:bg-pink-400 px-6 py-2 rounded-lg shadow-md">
  Agendar
</button>
    </div>

   
    <div class="bg-white w-72 p-6 rounded-2xl shadow-lg text-center hover:scale-105 transition flex flex-col">
      <h3 class="text-xl font-bold mb-2">🩺 Consultas Veterinária </h3>
      <p class="text-gray-700 font-semibold">R$80,90</p>
      <p class="mt-2 text-sm">Atendimento com profissionais qualificados para cuidar da saúde do seu pet, com avaliação, diagnóstico e orientações para o bem-estar.</p>
      <button class="mt-auto bg-pink-300 hover:bg-pink-400 px-6 py-2 rounded-lg shadow-md">
  Agendar
</button>
    </div>

  
<div class="bg-white w-72 p-6 rounded-2xl shadow-lg text-center hover:scale-105 transition flex flex-col">
      <h3 class="text-xl font-bold mb-2">💉Vacinação</h3>
      <p class="text-gray-700 font-semibold">R$150,90</p>
      <p class="mt-2 text-sm">Proteja seu pet contra diversas doenças com um calendário de vacinação seguro e atualizado, garantindo mais saúde e longevidade.</p>
      <button class="mt-auto bg-pink-300 hover:bg-pink-400 px-6 py-2 rounded-lg shadow-md">
  Agendar
</button>
    </div>

   
    <div class="bg-pink-100 border-2 border-pink-400 w-72 p-6 rounded-2xl shadow-xl text-center hover:scale-105 transition flex flex-col">
      <h3 class="text-xl font-bold mb-2">🛁 Pet Spa</h3>
      <p class="text-pink-700 font-bold">R$250,00</p>
      <p class="text-sm">Momentos de relaxamento e cuidado especial com hidratação, massagem e tratamentos que deixam seu pet calmo, saudável e feliz.

    
      </p>
      <button class="mt-auto bg-pink-300 hover:bg-pink-400 px-6 py-2 rounded-lg shadow-md">
  Agendar
</button>
    </div>

  </div>
</section>


<!-- FOOTER -->
<footer id="contatos" class="bg-white-300 text-center py-6">

    <div class="flex justify-center gap-6 font-bold mb-3 flex-wrap">
        <a href="#" class="hover:text-pink-800">📸 Instagram</a>
        <a href="#" class="hover:text-pink-800">💬 WhatsApp</a>
        <a href="#" class="hover:text-pink-800">✉️ Email</a>
    </div>

    <p class="text-sm">© 2026 PetVille - Todos os direitos reservados</p>

</footer>
<script src="js/gerenciamentoCategoria.js"></script>
</body>
</html>
