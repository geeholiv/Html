<!doctype html>
<html class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <title>PetVille</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- fonte -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="pt-16 bg-[#fffdf8] text-gray-800 font-[Poppins]">

<!-- HEADER -->
<header class="fixed top-0 w-full bg-white/90 backdrop-blur-md shadow-sm border-b border-gray-100 z-50">

  <div class="max-w-7xl mx-auto px-6 py-2">

    <!-- linha principal -->
    <div class="grid grid-cols-3 items-center">

      <!-- logo -->
      <img src="imgs/petville.png"
      class="w-24 md:w-32 hover:scale-105 transition duration-300 cursor-pointer">

      <!-- busca -->
      <div class="relative w-[250px] md:w-[520px] mx-auto">

        <img src="imgs/lupa.png"
        class="absolute left-4 top-1/2 -translate-y-1/2 w-4 opacity-60">

        <input
        type="text"
        placeholder="O que seu pet precisa?"
        class="w-full pl-11 pr-4 py-2 bg-[#f6f6f6] rounded-full outline-none border border-transparent focus:border-pink-200 focus:ring-4 focus:ring-pink-100 transition">
        
      </div>

      <!-- config -->
      <div class="flex justify-end">
        <img src="imgs/config.png"
        class="w-7 cursor-pointer transition duration-300 hover:scale-110 hover:rotate-12 active:scale-95 opacity-80 hover:opacity-100"
        onclick="window.location.href='gerenc.html'">
      </div>

    </div>

    <!-- menu -->
    <nav class="flex justify-center gap-8 mt-2 text-gray-700 font-medium text-[15px]">

      <a href="#home"
      class="relative hover:text-green-500 transition after:absolute after:left-0 after:-bottom-1 after:w-0 after:h-[2px] after:bg-green-400 after:transition-all hover:after:w-full">
      Home
      </a>

      <a href="#categorias"
      class="relative hover:text-green-500 transition after:absolute after:left-0 after:-bottom-1 after:w-0 after:h-[2px] after:bg-green-400 after:transition-all hover:after:w-full">
      Categorias
      </a>

      <a href="#servicos"
      class="relative hover:text-green-500 transition after:absolute after:left-0 after:-bottom-1 after:w-0 after:h-[2px] after:bg-green-400 after:transition-all hover:after:w-full">
      Serviços
      </a>

      <a href="#contatos"
      class="relative hover:text-green-500 transition after:absolute after:left-0 after:-bottom-1 after:w-0 after:h-[2px] after:bg-green-400 after:transition-all hover:after:w-full">
      Contatos
      </a>

    </nav>

  </div>

</header>

<!-- HERO -->
<section id="home"
class="relative overflow-hidden bg-gradient-to-b from-[#fffdf8] to-[#fef6f8]">

  <!-- blobs decorativos -->
  <div class="absolute top-0 left-0 w-72 h-72 bg-green-200 rounded-full blur-3xl opacity-30"></div>

  <div class="absolute bottom-0 right-0 w-72 h-72 bg-pink-200 rounded-full blur-3xl opacity-30"></div>

  <div class="max-w-7xl mx-auto px-6 py-28 md:py-40 relative z-10">

    <!-- badge -->
    <div class="inline-flex items-center gap-2 bg-white shadow-sm border border-pink-100 rounded-full px-5 py-2 mb-8">

      <span class="text-pink-400 text-lg">
        ❤
      </span>

      <p class="text-sm font-medium text-lime-700">
        Bem-estar, saúde e muito amor
      </p>

    </div>

    <!-- título -->
    <h1 class="text-5xl md:text-7xl font-bold leading-tight text-[#7d9b52] max-w-3xl">

      Cuidado e carinho
      <span class="text-pink-300">
        para cada pet
      </span>

    </h1>

    <!-- descrição -->
    <p class="mt-8 text-gray-600 text-lg md:text-xl max-w-2xl leading-relaxed">

      Serviços completos para deixar seu pet saudável,
      feliz e cheio de vida.

    </p>

    <!-- botões -->
    <div class="flex flex-wrap gap-5 mt-10">

      <button
      onclick="document.getElementById('servicos').scrollIntoView({behavior:'smooth'})"
      class="bg-pink-300 hover:bg-pink-400 text-gray-800 font-medium px-8 py-4 rounded-2xl shadow-md transition duration-300 hover:scale-105">

      Conheça nossos serviços

      </button>

      <button
      onclick="document.getElementById('categorias').scrollIntoView({behavior:'smooth'})"
      class="bg-white border border-gray-200 hover:border-pink-200 px-8 py-4 rounded-2xl font-medium shadow-sm hover:shadow-md transition">

      Ver categorias

      </button>

    </div>

    <!-- infos -->
    <div class="flex flex-wrap gap-10 mt-16">

      <div class="flex items-center gap-3">

        <div class="w-12 h-12 bg-green-100 rounded-2xl flex items-center justify-center text-xl">
          🐾
        </div>

        <div>
          <p class="font-semibold text-gray-800">
            Atendimento
          </p>

          <p class="text-sm text-gray-500">
            com amor
          </p>
        </div>

      </div>

      <div class="flex items-center gap-3">

        <div class="w-12 h-12 bg-pink-100 rounded-2xl flex items-center justify-center text-xl">
          🩺
        </div>

        <div>
          <p class="font-semibold text-gray-800">
            Profissionais
          </p>

          <p class="text-sm text-gray-500">
            qualificados
          </p>
        </div>

      </div>

      <div class="flex items-center gap-3">

        <div class="w-12 h-12 bg-lime-100 rounded-2xl flex items-center justify-center text-xl">
          ✨
        </div>

        <div>
          <p class="font-semibold text-gray-800">
            Ambiente
          </p>

          <p class="text-sm text-gray-500">
            seguro e acolhedor
          </p>
        </div>

      </div>

    </div>

  </div>

</section>

<!-- CATEGORIAS -->
<section id="categorias"
class="bg-[#edf5dc] py-24 px-8 relative overflow-hidden">
  <!-- detalhes decorativos -->
  <div class="absolute top-0 left-0 w-72 h-72 bg-pink-200 rounded-full blur-3xl opacity-20"></div>
  <div class="absolute bottom-0 right-0 w-72 h-72 bg-green-200 rounded-full blur-3xl opacity-20"></div>

  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-16 relative z-10">

    <!-- título -->
    <div class="md:w-1/4 flex justify-center items-center">

      <h2 class="text-5xl md:text-6xl font-bold text-[#7d9b52] leading-tight text-center">
        Para <br>
        cada Pet
      </h2>

    </div>

    <!-- categorias -->
    <div class="md:w-3/4">

      <div id="categoriasHome"
      class="grid grid-cols-2 md:grid-cols-4 gap-8">
      </div>

    </div>

  </div>

</section>

<!-- SERVIÇOS -->
<section id="servicos"
class="py-24 bg-gradient-to-b from-rose-100 to-rose-200">

  <h4 class="text-center text-[#7d9b52] font-bold text-3xl mb-14">
    Cuidados Essenciais
  </h4>

  <div class="flex flex-wrap justify-center gap-10 px-6">

    <!-- CARD -->
    <div class="bg-white/80 backdrop-blur-sm w-72 p-7 rounded-3xl shadow-md hover:shadow-2xl hover:-translate-y-2 transition duration-300 text-center flex flex-col border border-white">

      <h3 class="text-2xl font-bold mb-2">
        🐾 Banho e Tosa
      </h3>

      <p class="text-gray-700 font-semibold text-lg">
        R$80,90
      </p>

      <p class="mt-3 text-sm leading-relaxed text-gray-600">
        Higiene completa e cuidado especial para deixar seu pet limpo, cheiroso e com o visual sempre em dia.
      </p>

      <button
      class="mt-6 bg-pink-300 hover:bg-pink-400 text-gray-800 font-medium px-6 py-3 rounded-xl shadow-md transition duration-300 hover:scale-105"
      onclick="window.location.href='banhoetosa.html'">

      Ver mais

      </button>

    </div>

    <!-- CARD -->
    <div class="bg-white/80 backdrop-blur-sm w-72 p-7 rounded-3xl shadow-md hover:shadow-2xl hover:-translate-y-2 transition duration-300 text-center flex flex-col border border-white">

      <h3 class="text-2xl font-bold mb-2">
        🩺 Consultas
      </h3>

      <p class="text-gray-700 font-semibold text-lg">
        R$99,99
      </p>

      <p class="mt-3 text-sm leading-relaxed text-gray-600">
        Atendimento veterinário com profissionais qualificados para cuidar da saúde e bem-estar do seu pet.
      </p>

      <button
      class="mt-6 bg-pink-300 hover:bg-pink-400 text-gray-800 font-medium px-6 py-3 rounded-xl shadow-md transition duration-300 hover:scale-105"
      onclick="window.location.href='consulta.html'">

      Ver mais

      </button>

    </div>

    <!-- CARD -->
    <div class="bg-white/80 backdrop-blur-sm w-72 p-7 rounded-3xl shadow-md hover:shadow-2xl hover:-translate-y-2 transition duration-300 text-center flex flex-col border border-white">

      <h3 class="text-2xl font-bold mb-2">
        💉 Vacinação
      </h3>

      <p class="text-gray-700 font-semibold text-lg">
        R$150,90
      </p>

      <p class="mt-3 text-sm leading-relaxed text-gray-600">
        Vacinas seguras e atualizadas para proteger seu pet contra doenças e garantir mais saúde.
      </p>

      <button
      class="mt-12 bg-pink-300 hover:bg-pink-400 text-gray-800 font-medium px-6 py-3 rounded-xl shadow-md transition duration-300 hover:scale-105"
      onclick="window.location.href='vacinacao.html'">

      Ver mais

      </button>

    </div>

    <!-- destaque -->
    <div class="bg-pink-100 w-72 p-7 rounded-3xl shadow-xl hover:shadow-2xl hover:-translate-y-2 transition duration-300 text-center flex flex-col border-2 border-pink-300">

      <h3 class="text-2xl font-bold mb-2">
        🛁 Pet Spa
      </h3>

      <p class="text-pink-700 font-bold text-lg">
        R$250,00
      </p>

      <p class="mt-3 text-sm leading-relaxed text-gray-700">
        Hidratação, relaxamento e tratamentos especiais para deixar seu pet ainda mais feliz.
      </p>

      <button
      class="mt-12 bg-pink-400 hover:bg-pink-500 text-white font-medium px-6 py-3 rounded-xl shadow-md transition duration-300 hover:scale-105"
      onclick="window.location.href='petspa.html'">

      Ver mais

      </button>

    </div>

  </div>

</section>

<!-- FOOTER -->
<footer id="contatos"
class="bg-white border-t border-gray-200 text-center py-10">

  <div class="flex justify-center gap-8 font-medium mb-5 flex-wrap text-gray-700">

    <a href="#"
    class="hover:text-pink-600 hover:-translate-y-1 transition">
    📸 Instagram
    </a>

    <a href="#"
    class="hover:text-pink-600 hover:-translate-y-1 transition">
    💬 WhatsApp
    </a>

    <a href="#"
    class="hover:text-pink-600 hover:-translate-y-1 transition">
    ✉️ Email
    </a>

  </div>

  <p class="text-sm text-gray-500">
    © 2026 PetVille - Todos os direitos reservados
  </p>

</footer>

<script src="js/gerenciamentoCategoria.js"></script>

</body>
</html>
