<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Gerenciamento Categorias</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="font-sans bg-white-200 min-h-screen flex flex-col pt-20">
<header class="fixed top-0 w-full bg-white shadow-sm z-50">

  <div class="max-w-7xl mx-auto px-4 py-1">

    <!-- linha principal -->
    <div class="grid grid-cols-3 items-center">

  <!-- logo -->
  <div>
    <img src="imgs/petville.png" class="w-28 md:w-20 h-auto">
  </div>

  <!-- espaço vazio (centro) -->
  <div></div>

  <!-- ícone home -->
  <div class="flex justify-end">
    <img src="imgs/home.png"
         class="w-6 cursor-pointer transition duration-200 transform hover:scale-110 active:scale-95"
         onclick="window.location.href='home.html'">
  </div>

</div>
    </header>

<div class="bg-white px-9 py-3 rounded-xl w-full max-w-xl shadow-2xl mx-auto flex-grow mt-20">
    <h2 id="titulo" class="text-center mb-6 text-gray-800 text-xl font-semibold">
       Gerenciar Categorias
    </h2>

    <form id="categoriaForm">
        <input type="hidden" id="id">

        <!-- Foto -->
        <div class="mb-4">
            <label class="block font-semibold mb-1 text-pink-400">Foto ou ícone</label>
            <input type="file" id="fotoInput" accept="image/*" class="w-full">
            <img id="preview" src="imgs/iconegato.png"
                class="hidden w-24 mt-2 rounded-full">
        </div>

        
        <div class="mb-4">
            <label class="block font-semibold mb-1 text-pink-400">Nome</label>
            <input type="text" id="nome" required
                class="w-full px-1 py-2 rounded-lg border border-pink-400 text-sm focus:outline-none focus:border-green-300 focus:ring-2 focus:ring-indigo-200">
        </div>

        
        <div class="mb-4">
            <label class="block font-semibold mb-1 text-pink-400">Descrição</label>
            <input type="text" id="descricao" required
                class="w-full px-1 py-2 rounded-lg border border-pink-400 text-sm focus:outline-none focus:border-green-300 focus:ring-2 focus:ring-indigo-200">
        </div>

    

        <!-- Botão -->
        <button type="submit" id="btnSalvar"
            class="w-full py-3 mt-2 bg-rose-300 hover:bg-rose-200 text-white font-semibold rounded-lg transition">
            Salvar
        </button>
    </form>

    <div id="listaCategorias" class="grid grid-cols-2 gap-4 mt-6"></div>

    <!-- Mensagem -->
    <div id="mensagem" class="mt-4 text-center font-semibold"></div>
</div>

<footer id="contatos" class="bg-white-300 text-center py-10 border-pink-200">

    <div class="flex justify-center gap-6 font-bold mb-3 flex-wrap">
        <a href="#" class="hover:text-pink-800">📸 Instagram</a>
        <a href="#" class="hover:text-pink-800">💬 WhatsApp</a>
        <a href="#" class="hover:text-pink-800">✉️ Email</a>
    </div>

    <p class="text-sm">© 2026 PetVille - Todos os direitos reservados</p>

</footer>
<script src="js/admin.js"></script>
</body>
</html>
